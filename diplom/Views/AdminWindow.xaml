<Window x:Class="diplom.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:diplom.Views"
        mc:Ignorable="d"
        Title="Панель администратора — ХМТПК" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#F8F9FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Управление промежуточной аттестацией и графиками пересдач" 
                   Style="{StaticResource MainTitleStyle}"/>

        <!-- Боковая навигация -->
        <Border Grid.Row="1" Grid.Column="0" Grid.RowSpan="3" Style="{StaticResource ModernBorder}" HorizontalAlignment="Left" Width="225">
            <StackPanel Margin="10">
                <TextBlock Text="Навигация" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,10"/>
                <Button x:Name="BtnRunAlgorithm"
                        MinHeight="44"
                        HorizontalAlignment="Stretch"
                        Padding="8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,0,10"
                        Click="BtnRunAlgorithm_Click">
                    <TextBlock Text="⚙ Сформировать график (ИИ)" TextWrapping="Wrap" TextAlignment="Left"/>
                </Button>

                <Button x:Name="BtnViewDebts"
                        MinHeight="44"
                        HorizontalAlignment="Stretch"
                        Padding="8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,0,10"
                        Click="BtnViewDebts_Click">
                    <TextBlock Text="📋 Просмотр долгов" TextWrapping="Wrap" TextAlignment="Left"/>
                </Button>

                <Button x:Name="BtnManageAssignments"
                        MinHeight="44"
                        HorizontalAlignment="Stretch"
                        Padding="8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,0,10"
                        Click="BtnManageAssignments_Click">
                    <TextBlock Text="👥 Привязка преподавателей к предметам" TextWrapping="Wrap" TextAlignment="Left"/>
                </Button>


                <Separator Margin="0,10"/>
            </StackPanel>
        </Border>

        <!-- Верхняя правая панель кнопок -->
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button x:Name="BtnAddDebt" 
                    MinHeight="36"
                    Padding="6"
                    Width="160"
                    Style="{StaticResource SuccessButtonStyle}"
                    Margin="0,0,10,0"
                    Click="BtnAddDebt_Click">
                <TextBlock Text="➕ Добавить должника" TextWrapping="Wrap" TextAlignment="Center"/>
            </Button>

            <Button x:Name="BtnImportExcel" 
                    MinHeight="36"
                    Padding="6"
                    Width="160"
                    Style="{StaticResource SuccessButtonStyle}"
                    Margin="0,0,10,0"
                    Click="BtnImportExcel_Click">
                <TextBlock Text="📥 Импорт из Excel" TextWrapping="Wrap" TextAlignment="Center"/>
            </Button>

            <Button x:Name="BtnExportExcel" 
                    MinHeight="36"
                    Padding="6"
                    Width="160"
                    Style="{StaticResource SuccessButtonStyle}"
                    Margin="0,0,10,0"
                    Click="BtnExportExcel_Click">
                <TextBlock Text="📤 Экспорт в Excel" TextWrapping="Wrap" TextAlignment="Center"/>
            </Button>

            <Button x:Name="BtnRefresh" 
                    MinHeight="36"
                    Padding="6"
                    Width="120"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="BtnRefresh_Click">
                <TextBlock Text="🔄 Обновить" TextWrapping="Wrap" TextAlignment="Center"/>
            </Button>
        </StackPanel>

        <Grid Grid.Row="2" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" 
                      Header="Текущие активные задолженности студентов колледжа" 
                      Style="{StaticResource ModernGroupBox}">
                <DataGrid x:Name="DgAdminDebts" 
                          Style="{StaticResource ModernDataGrid}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          Margin="10"
                          ItemsSource="{Binding}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№ зачетки" Binding="{Binding StudentCardNumber}" Width="0.9*"/>
                        <DataGridTextColumn Header="Студент (ФИО)" Binding="{Binding StudentName}" Width="2*"/>
                        <DataGridTextColumn Header="Группа" Binding="{Binding GroupName}" Width="1*"/>
                        <DataGridTextColumn Header="Дисциплина" Binding="{Binding DisciplineName}" Width="2*"/>
                        <DataGridTextColumn Header="Преподаватель" Binding="{Binding TeacherName}" Width="1.5*"/>
                        <DataGridTextColumn Header="Кабинет" Binding="{Binding ClassroomNumber}" Width="1*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#2980B9"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Пара" Binding="{Binding TimeSlotID}" Width="0.6*"/>
                        <DataGridTextColumn Header="Дата экзамена" Binding="{Binding ExamDate, StringFormat='dd.MM.yyyy'}" Width="1.2*"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="1*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#C0392B"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <!-- Нижняя панель с кнопками выхода и информацией -->
        <Border Grid.Row="3" Grid.ColumnSpan="2"
                Style="{StaticResource ModernBorder}"
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock x:Name="TxtStatus" 
                           Text="Статус: готово" 
                           Style="{StaticResource NormalTextStyle}"
                           Foreground="#27AE60"
                           FontWeight="Bold"
                           Margin="0,0,20,0"/>
                <Button Content="← Вернуться на главное меню" 
                        Style="{StaticResource DangerButtonStyle}"
                        Click="BtnBackToMain_Click"
                        MinWidth="260"
                        Padding="8,6"
                        HorizontalAlignment="Right"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
