<Window x:Class="diplom.Views.StudentGuestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:diplom.Views"
        mc:Ignorable="d"
       Title="Гостевой контур студента — ХМТПК" Height="450" Width="700" 
        WindowStartupLocation="CenterScreen" Background="#F5F6F8">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="2" x:Name="BtnExit" Content="↩  На страницу входа" Width="150" Height="30" Margin="10,0,0,0" 
        Background="Gray" Foreground="White" FontWeight="Medium" Click="BtnExit_Click" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
        
        <TextBlock Text="Проверка академических задолженностей" 
                   FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Введите номер зачётной книжки:" VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0"/>
            <TextBox x:Name="TxtCardNumber" Width="200" Height="28" VerticalContentAlignment="Center" FontSize="14"/>
            <Button x:Name="BtnSearch" Content="Проверить" Width="100" Height="28" Margin="10,0,0,0" 
                    Background="#34495E" Foreground="White" FontWeight="Bold" Click="BtnSearch_Click"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Border x:Name="SuccessPanel" Background="#E8F8F5" BorderBrush="#2ECC71" BorderThickness="1" CornerRadius="5" Padding="20" Visibility="Collapsed" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✔" Foreground="#2ECC71" FontSize="24" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Академические задолженности не обнаружены. Вы успешно прошли аттестацию!" 
                               Foreground="#117A65" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel x:Name="DebtPanel" Visibility="Collapsed">
                <TextBlock Text="⚠ Обнаружены задолженности. График повторных аттестаций:" 
                           Foreground="#C0392B" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                <DataGrid x:Name="DgSchedule" AutoGenerateColumns="False" IsReadOnly="True" 
                          Background="White" RowBackground="#FDFEFE" AlternatingRowBackground="#F4F6F7"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E5E7E9">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дисциплина" Binding="{Binding DisciplineName}" Width="2*"/>
                        <DataGridTextColumn Header="Преподаватель" Binding="{Binding TeacherName}" Width="1.5*"/>
                        <DataGridTextColumn Header="Дата пересдачи" Binding="{Binding ExamDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="1*"/>
                        <DataGridTextColumn Header="Номер пары" Binding="{Binding TimeSlot}" Width="0.8*"/>
                        <DataGridTextColumn Header="Аудитория" Binding="{Binding ClassroomNumber}" Width="0.8*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
