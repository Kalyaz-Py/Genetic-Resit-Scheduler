<Window x:Class="diplom.Views.ImportReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчёт импорта" Height="500" Width="800" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <GroupBox Header="Строки, не импортированные/ошибки" Style="{StaticResource ModernGroupBox}">
            <DataGrid x:Name="DgReport" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Row}" Width="40"/>
                    <DataGridTextColumn Header="Зачетка" Binding="{Binding CardNumber}" Width="120"/>
                    <DataGridTextColumn Header="Дисциплина" Binding="{Binding Discipline}" Width="*"/>
                    <DataGridTextColumn Header="Оценка" Binding="{Binding Grade}" Width="80"/>
                    <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,10,0,0">
            <Button Content="Закрыть" Width="120" Margin="5" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
