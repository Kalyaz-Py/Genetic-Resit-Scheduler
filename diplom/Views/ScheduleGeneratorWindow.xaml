<Window x:Class="diplom.Views.ScheduleGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:diplom.Views"
        mc:Ignorable="d"
        Title="Составление графика пересдач — Параметры" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" 
        Background="#F4F6F7"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Параметры генерации расписания" 
                   Style="{StaticResource MainTitleStyle}"/>

        <!-- Выбор типа периода -->
        <GroupBox Grid.Row="1" Grid.Column="0" Header="Выбор периода составления расписания" Style="{StaticResource ModernGroupBox}">
            <StackPanel Margin="10">
                <Border Style="{StaticResource ModernBorder}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Сформировать расписание на период (диапазон дат)" Foreground="#34495E" FontSize="12" Margin="0,0,0,10"/>
                        <Grid Margin="20,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Начало периода:" Style="{StaticResource FormLabelStyle}"/>
                                <DatePicker Style="{StaticResource ModernDatePicker}"
                                            SelectedDate="{Binding StartDate, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Конец периода:" Style="{StaticResource FormLabelStyle}"/>
                                <DatePicker Style="{StaticResource ModernDatePicker}"
                                            SelectedDate="{Binding EndDate, Mode=TwoWay}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </GroupBox>

        <!-- Параметры расписания (более компактный и практичный набор) -->
        <GroupBox Grid.Row="2" Grid.Column="0"
                  Header="Параметры расписания" 
                  Style="{StaticResource ModernGroupBox}">
            <StackPanel Margin="10">
                <!-- Поле выбора статуса задолженности удалено по запросу -->

                <CheckBox Content="Учитывать занятость аудиторий" 
                          IsChecked="{Binding ConsiderRoomAvailability, Mode=TwoWay}" 
                          Margin="0,0,6,6"/>

                <CheckBox Content="Разделять студентов по потокам/группам"
                          IsChecked="{Binding SplitByStreams, Mode=TwoWay}"
                          Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock Text="Максимум пересдач в день на студента:" VerticalAlignment="Center" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Width="60" Margin="8,0,0,0" Text="{Binding MaxRetakesPerDay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <TextBlock Text="Подсказка: алгоритм оптимизации настраивается автоматически; эти параметры влияют на жёсткость ограничений." 
                           Style="{StaticResource NormalTextStyle}"
                           Foreground="#3498DB"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>

        <!-- Список студентов для выбора конкретных участников пересдачи -->
        <GroupBox Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Header="Выбор студентов" Style="{StaticResource ModernGroupBox}">
            <StackPanel Margin="10">
                <TextBlock Text="Отметьте студентов, которым нужно назначить пересдачу:" Style="{StaticResource FormLabelStyle}"/>

                <DockPanel Margin="0,8,0,6">
                    <TextBox x:Name="TxtSearch" DockPanel.Dock="Left" Width="220" Margin="0,0,8,0" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Выбрать всё" Command="{Binding SelectAllCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Padding="8,4" Width="122"/>
                    <Button Content="Снять все" Command="{Binding ClearAllCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Width="86"/>
                </DockPanel>

                <ListBox ItemsSource="{Binding FilteredStudents}" Margin="0,8,0,6" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" MaxHeight="420">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Padding="6">
                                <TextBlock Text="{Binding StudentName}" TextWrapping="Wrap"/>
                            </CheckBox>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>


            </StackPanel>
        </GroupBox>

        <!-- Нижние кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnCancel" 
                    Content="✕ Отмена" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="BtnCancel_Click"
                    Margin="0,0,10,0" Width="120"/>
            <Button x:Name="BtnGenerate" 
                    Content="⚙ Сформировать" 
                    Style="{StaticResource SuccessButtonStyle}"
                    Click="BtnGenerate_Click"
                    Width="160"/>
        </StackPanel>
    </Grid>
</Window>
