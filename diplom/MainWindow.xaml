<Window x:Class="diplom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:diplom"
        mc:Ignorable="d"
       Title="Информационная система ХМТПК — Главное меню" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F4F6F7" ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <Grid Background="#2C3E50">
            <StackPanel VerticalAlignment="Center" Margin="20">
                <Image Source="/Resources/logo.png" />
                <TextBlock Text="ХМТПК" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Учет аттестации и графиков пересдач" Foreground="#BDC3C7" FontSize="12" 
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0"/>
                <Separator Background="#34495E" Margin="0,20,0,20"/>
                <TextBlock Text="v1.0" Foreground="#7F8C8D" FontSize="11" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Margin="25,20,25,20" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Выберите режим входа" FontSize="18" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <Button x:Name="BtnStudentMode" Content="👨‍🎓 Войти как Студент" Height="40" 
                        Background="#2ECC71" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0"
                        Click="BtnStudentMode_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock Text="или войдите как сотрудник:" Foreground="#95A5A6" FontSize="11" HorizontalAlignment="Center" Margin="0,20,0,10"/>

                <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" Padding="15" Background="White">
                    <StackPanel>
                        <TextBlock Text="Логин:" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBox x:Name="TxtLogin" Height="26" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                        <TextBlock Text="Пароль:" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <PasswordBox x:Name="TxtPassword" Height="26" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

                        <Button x:Name="BtnAdminLogin" Content="🔒 Войти в панель" Height="30" 
                                Background="#3498DB" Foreground="White" FontWeight="Bold" FontSize="12" BorderThickness="0"
                                Click="BtnAdminLogin_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
