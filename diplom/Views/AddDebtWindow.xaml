<Window x:Class="diplom.Views.AddDebtWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:diplom.Views"
        xmlns:conv="clr-namespace:diplom.Converters"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Добавление задолженности студента" 
        Height="700" Width="600"
        WindowStartupLocation="CenterScreen" 
        Background="#F4F6F7"
        ResizeMode="NoResize">

    <Window.Resources>
        <conv:FirstLetterConverter x:Key="FirstLetterConverter" />
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Добавить новую задолженность" 
                   Style="{StaticResource MainTitleStyle}"/>

        <!-- Информационный текст -->
        <TextBlock Grid.Row="1"
                   Text="Заполните форму для добавления нового должника в систему"
                   Style="{StaticResource NormalTextStyle}"
                   Foreground="#7F8C8D"
                   Margin="0,0,0,20"/>

        <!-- Форма -->
        <GroupBox Grid.Row="2" 
                  Header="Параметры задолженности" 
                  Style="{StaticResource ModernGroupBox}">
            <StackPanel Margin="10">
                <!-- Студент -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Студент *" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox x:Name="CbStudents"
                              Style="{StaticResource ModernComboBox}"
                              ItemsSource="{Binding Students}"
                              SelectedItem="{Binding SelectedStudent, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} - {1} {2} {3}">
                                            <Binding Path="StudentCardNumber"/>
                                            <Binding Path="LastName"/>
                                            <Binding Path="FirstName"/>
                                            <Binding Path="MiddleName"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Дисциплина -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Дисциплина *" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox Style="{StaticResource ModernComboBox}"
                              ItemsSource="{Binding FilteredDisciplines}"
                              SelectedItem="{Binding SelectedDiscipline, Mode=TwoWay}"
                              DisplayMemberPath="DisciplineName"/>
                </StackPanel>

                <!-- Преподаватель -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Преподаватель *" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox Style="{StaticResource ModernComboBox}"
                              ItemsSource="{Binding Teachers}"
                              SelectedItem="{Binding SelectedTeacher, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} {1}. {2}.">
                                            <Binding Path="LastName"/>
                                            <Binding Path="FirstName" Converter="{StaticResource FirstLetterConverter}"/>
                                            <Binding Path="MiddleName" Converter="{StaticResource FirstLetterConverter}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Статус -->
                <StackPanel Margin="0,0,0,0">
                    <TextBlock Text="Статус" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox Style="{StaticResource ModernComboBox}"
                              SelectedItem="{Binding DebtStatus, Mode=TwoWay}">
                        <ComboBox.Items>
                            <System:String>Активна</System:String>
                            <System:String>Перенесена</System:String>
                            <System:String>Выполнена</System:String>
                        </ComboBox.Items>
                    </ComboBox>
                </StackPanel>

                <TextBlock Text="* - обязательные поля"
                           Style="{StaticResource NormalTextStyle}"
                           Foreground="#E74C3C"
                           Margin="0,20,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Нижние кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnCancel" 
                    Content="✕ Отмена" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="BtnCancel_Click"
                    Margin="0,0,10,0" Width="120"/>
            <Button x:Name="BtnAdd" 
                    Content="✓ Добавить" 
                    Style="{StaticResource SuccessButtonStyle}"
                    Click="BtnAdd_Click"
                    Width="120"/>
        </StackPanel>
    </Grid>
</Window>
